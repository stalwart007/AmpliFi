{
  "name": "@amplifi/quant-core",
  "version": "0.1.0",
  "description": "Deterministic, dependency-free quant core: Black-Scholes greeks, implied vol, SVI surface, full-revaluation Monte-Carlo VaR.",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx test/verify.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
