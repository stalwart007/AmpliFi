{
  "name": "@amplifi/portfolio-opt",
  "version": "0.1.0",
  "description": "Portfolio optimisation: mean-variance (min-variance, tangency, frontier), risk-budgeting/ERC, and Black–Litterman.",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": ["dist", "src"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } }
  },
  "scripts": {
    "test": "tsx test/verify.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@amplifi/quant-core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
