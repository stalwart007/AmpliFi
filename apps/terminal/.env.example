# WalletConnect / Reown project id — get a free one at https://cloud.reown.com
# Enables WalletConnect + mobile wallets in the RainbowKit modal.
# Without it, browser-extension wallets still work (MetaMask, Rabby, Coinbase…).
VITE_WC_PROJECT_ID=

# Live vault (leave VITE_VAULT_ADDRESS unset to run the in-browser simulation).
# Set to a deployed AmplifiGatedVault to drive the real contracts on-chain.
VITE_VAULT_ADDRESS=
VITE_RPC_URL=http://127.0.0.1:8545
VITE_CHAIN_ID=1
