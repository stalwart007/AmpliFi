{
  "name": "amplifi-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "AmpliFi — leveraged, capped-downside synthetic crypto index. Monorepo: shared quant core, strategy engine, services, apps, and on-chain.",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*",
    "contracts"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint packages",
    "format": "prettier --check \"packages/**/*.{ts,json,md}\" \"*.{json,md}\"",
    "format:write": "prettier --write \"packages/**/*.{ts,json,md}\" \"*.{json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.15.0"
  }
}
